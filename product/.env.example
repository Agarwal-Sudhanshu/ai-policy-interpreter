# Required for AI interpretation in /api/analyze
OPENAI_API_KEY=sk-your-openai-api-key-here

# Pipeline (generate-policy-chunks) needs this to insert into policy_chunks when RLS is enabled.
# From Supabase: Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Background jobs (Inngest): internal calls to process-policy and extract-rules use this secret.
# Generate a random string (e.g. openssl rand -hex 32) and set the same value in Inngest dashboard if needed.
INTERNAL_API_SECRET=your-internal-secret-here

# Inngest Cloud: from dashboard (Settings → Keys). Required for production; optional for local dev.
# INNGEST_SIGNING_KEY=signkey-prod-...

# App URL for Inngest to call back (Vercel sets VERCEL_URL automatically). For local dev only:
# APP_URL=http://localhost:3000
